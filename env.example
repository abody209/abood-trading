# Copy this file to .env and fill in your values

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"

# Telegram Channel/Group/User ID to send messages to
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# A secret string to secure your webhook endpoint
WEBHOOK_SECRET="joker_secret_change_me"

# Optional: Override default settings
# MIN_SIGNAL_SCORE="2.5"
# BOT_TIMEZONE="Asia/Riyadh"
# ENABLE_TRADING_HOURS="true"
