# ABOOD القناص V1.0 - Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"

# Telegram Channel/Group/User ID to send messages to
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# Webhook Secrets (one for each TradingView indicator)
WEBHOOK_SECRET="abood_sniper_v1_secret"
GAINZALGO_SECRET="gainzalgo_secret"
LUXALGO_SECRET="luxalgo_secret"

# Trading Hours (UTC) - 3:00 AM to 11:00 PM Riyadh
ENABLE_TRADING_HOURS="true"
TRADING_START_HOUR="0"
TRADING_END_HOUR="20"

# Trading Days
ENABLE_TRADING_DAYS="true"

# Server
PORT="8000"
HOST="0.0.0.0"
