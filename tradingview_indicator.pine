//@version=5
indicator("Joker Trading - Multi Indicator Scoring", shorttitle="Joker Score", overlay=true)

// =========================================================================
// INPUTS
// =========================================================================
// EMA
emaFast = input.int(9, title="EMA Fast", group="EMA")
emaSlow = input.int(21, title="EMA Slow", group="EMA")

// Bollinger Bands
bbLen = input.int(20, title="BB Length", group="Bollinger Bands")
bbMult = input.float(2.0, title="BB Multiplier", group="Bollinger Bands")

// RSI
rsiLen = input.int(14, title="RSI Length", group="RSI")
rsiOB = input.int(65, title="RSI Overbought", group="RSI")
rsiOS = input.int(35, title="RSI Oversold", group="RSI")

// Stochastic
stochK = input.int(14, title="Stoch %K", group="Stochastic")
stochD = input.int(3, title="Stoch %D", group="Stochastic")
stochSmooth = input.int(3, title="Stoch Smooth", group="Stochastic")
stochOB = input.int(80, title="Stoch Overbought", group="Stochastic")
stochOS = input.int(20, title="Stoch Oversold", group="Stochastic")

// ADX
adxLen = input.int(14, title="ADX Length", group="ADX")
adxThresh = input.float(25, title="ADX Threshold", group="ADX")

// Scoring
minScore = input.float(2.0, title="Min Score for Signal", group="Scoring")

// Webhook Secret
webhookSecret = input.string("joker_secret_change_me", title="Webhook Secret", group="Webhook")

// =========================================================================
// CALCULATIONS
// =========================================================================
// EMA
emaF = ta.ema(close, emaFast)
emaS = ta.ema(close, emaSlow)

// Bollinger Bands
basis = ta.sma(close, bbLen)
dev = bbMult * ta.stdev(close, bbLen)
upperBB = basis + dev
lowerBB = basis - dev

// RSI
rsi = ta.rsi(close, rsiLen)

// Stochastic
k = ta.sma(ta.stoch(close, high, low, stochK), stochSmooth)
d = ta.sma(k, stochD)

// ADX
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

// =========================================================================
// SCORING
// =========================================================================
var float callScore = 0.0
var float putScore = 0.0
callScore := 0.0
putScore := 0.0

// BB Score
if close <= lowerBB
    callScore += 1.0
if close >= upperBB
    putScore += 1.0

bbWidth = upperBB - lowerBB
if bbWidth > 0
    distLower = (close - lowerBB) / bbWidth
    distUpper = (upperBB - close) / bbWidth
    if distLower < 0.15
        callScore += 0.5
    if distUpper < 0.15
        putScore += 0.5

// RSI Score
if rsi <= rsiOS
    callScore += 1.0
else if rsi <= 45
    callScore += 0.5
if rsi >= rsiOB
    putScore += 1.0
else if rsi >= 55
    putScore += 0.5

// EMA Score
emaBullCross = emaF > emaS and emaF[1] <= emaS[1]
emaBearCross = emaF < emaS and emaF[1] >= emaS[1]
if emaBullCross
    callScore += 1.5
else if emaF > emaS
    callScore += 0.5
if emaBearCross
    putScore += 1.5
else if emaF < emaS
    putScore += 0.5

// Stochastic Score
if k <= stochOS and k > d
    callScore += 1.0
else if k <= 40
    callScore += 0.3
if k >= stochOB and k < d
    putScore += 1.0
else if k >= 60
    putScore += 0.3

// ADX Score
if adxVal < adxThresh
    if callScore > 0
        callScore += 0.5
    if putScore > 0
        putScore += 0.5
else
    if diPlus > diMinus
        callScore += 0.5
    else
        putScore += 0.5

// =========================================================================
// SIGNALS
// =========================================================================
callSignal = callScore >= minScore and callScore > putScore
putSignal = putScore >= minScore and putScore > callScore

// =========================================================================
// PLOTTING
// =========================================================================
plot(emaF, color=color.green, linewidth=1, title="EMA Fast")
plot(emaS, color=color.red, linewidth=1, title="EMA Slow")
p1 = plot(upperBB, color=color.blue, title="BB Upper")
p2 = plot(lowerBB, color=color.blue, title="BB Lower")
fill(p1, p2, color=color.new(color.blue, 92))

plotshape(callSignal, title="CALL", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.normal, text="CALL")
plotshape(putSignal, title="PUT", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.normal, text="PUT")

// Score label
if callSignal
    label.new(bar_index, low, "Score: " + str.tostring(callScore, "#.#"), style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if putSignal
    label.new(bar_index, high, "Score: " + str.tostring(putScore, "#.#"), style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

// =========================================================================
// ALERTS (Webhook-ready with secret)
// =========================================================================
alertcondition(callSignal, title="CALL Signal",
     message='{"symbol": "{{ticker}}", "signal": "CALL", "duration": "15", "price": "{{close}}", "score": "' + str.tostring(callScore) + '", "secret": "' + webhookSecret + '"}')

alertcondition(putSignal, title="PUT Signal",
     message='{"symbol": "{{ticker}}", "signal": "PUT", "duration": "15", "price": "{{close}}", "score": "' + str.tostring(putScore) + '", "secret": "' + webhookSecret + '"}')
